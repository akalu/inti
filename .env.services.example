# ==============================================
# KRONOS External Services Configuration
# ==============================================
# Copy this file to .env.services and fill in your keys.

# GitHub Personal Access Token (for higher API rate limits)
# Generate at: https://github.com/settings/tokens
# Scopes needed: public_repo (read-only)
GITHUB_TOKEN=

# VirusTotal API Key (for malware hash checking)
# Get free key at: https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute
VIRUSTOTAL_API_KEY=
