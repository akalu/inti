# ============================================================
# TAAS-AGI (KRONOS) — LLM Configuration
# ============================================================
# Copy this file to .env and fill in your API key.
# One API key powers all 8 cognitive systems.
#
# Supported providers: gemini, openai, ollama, simulation
# ============================================================

# --- Global Defaults (1 key = all 8 systems) ---
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
DEFAULT_LLM_API_KEY=your-gemini-api-key-here

# --- Per-System Overrides (optional, for advanced setups) ---
# Uncomment to assign different LLMs to different cognitive systems.
# Example: Will uses Claude for executive decisions, Reason uses GPT-4 for logic.
#
# WILL_LLM_PROVIDER=openai
# WILL_LLM_MODEL=gpt-4o
# WILL_LLM_API_KEY=your-openai-key
#
# REASON_LLM_PROVIDER=gemini
# REASON_LLM_MODEL=gemini-2.5-pro
# REASON_LLM_API_KEY=your-gemini-key
#
# For local models (no API key needed):
# INTELLECT_LLM_PROVIDER=ollama
# INTELLECT_LLM_MODEL=llama3

# ============================================================
# Hybrid Memory — ChromaDB + Gemini Embedding 2
# ============================================================
# The GEMINI_API_KEY is used for both LLM calls and embeddings.
# If DEFAULT_LLM_PROVIDER=gemini, the same API key is reused.
GEMINI_API_KEY=your-gemini-api-key-here

# ChromaDB persistence directory (default: data/chromadb)
# CHROMADB_PATH=data/chromadb

# Embedding model (default: gemini-embedding-2-preview)
# Fallback: gemini-embedding-001 (text-only, stable)
# EMBEDDING_MODEL=gemini-embedding-2-preview

# Embedding vector dimensions (default: 768 via MRL truncation)
# Options: 768, 1536, 3072 (higher = more accurate, more storage)
# EMBEDDING_DIMS=768

